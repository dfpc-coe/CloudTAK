{
    "name": "retention-service",
    "version": "0.0.0",
    "type": "module",
    "private": true,
    "engines": {
        "node": ">= 24"
    },
    "scripts": {
        "typegen": "npm run typegen -C ../../api",
        "check": "tsc --noEmit",
        "lint": "eslint src/",
        "build": "tsup --target es2022 --format esm src/",
        "dev": "tsx watch src/index.ts --noevents --nometrics --nosinks --unsafe",
        "prod": "NODE_OPTIONS='--max-old-space-size=6144' node dist/index.js",
        "run-once": "NODE_OPTIONS='--max-old-space-size=6144' node dist/index.js --run-once"
    },
    "dependencies": {
        "jsonwebtoken": "^9.0.0",
        "node-cron": "^4.2.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jsonwebtoken": "^9.0.0",
        "@types/node": "^25.0.0",
        "eslint": "^10.0.0",
        "tsup": "^8.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.0.0"
    }
}
