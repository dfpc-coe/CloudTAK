{
    "ts-node": {
        "esm": true
    },
    "compilerOptions": {
        "target": "es2022",
        "strict": true,
        "preserveConstEnums": true,
        "noEmit": true,
        "sourceMap": false,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "paths": {
            "@cloudtak/api-types": ["../../api/derived-types.d.ts"]
        }
    },
    "exclude": ["node_modules"]
}