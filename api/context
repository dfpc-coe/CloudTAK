if [[ -z $1 ]]; then
    Stack="cotak-prod"
else
    Stack=$1
fi

set -euo pipefail

echo "Loading $Stack"


cd ..

Repo=$(jq -r .name .deploy)
FullStack="${Repo}-${Stack}"

if [[ $Stack == *"staging"* ]]; then
    AwsProfile="coestaging"
    AwsRegion="us-east-1"
else
    AwsProfile=$(jq -r .profile .deploy)
    AwsRegion=$(jq -r .region .deploy)
fi

if [[ $Stack == *"staging"* ]]; then
    StackInfo=$(deploy info ${Stack} --profile coestaging --region us-east-1)
else
    StackInfo=$(deploy info ${Stack})
fi

# Postgres connection string (quoted JSON value, as the bastion pg_dump expects).
POSTGRES=$(echo "$StackInfo" | jq .Outputs.DB)

# Hosted URLs published as stack Outputs.
ApiUrl=$(echo "$StackInfo" | jq -r '.Outputs.APIURL // empty')
PmtilesUrl=$(echo "$StackInfo" | jq -r '.Outputs.PMTilesAPI // empty')

echo "Pulling secrets for ${FullStack} from AWS Secrets Manager"

SigningSecret=$(aws secretsmanager get-secret-value \
    --secret-id "${FullStack}/api/secret" \
    --query SecretString --output text \
    --profile "${AwsProfile}" --region "${AwsRegion}")

GeofenceSecret=$(aws secretsmanager get-secret-value \
    --secret-id "${FullStack}/api/geofence" \
    --query SecretString --output text \
    --profile "${AwsProfile}" --region "${AwsRegion}" 2>/dev/null || echo "")

AssetBucket=$(aws cloudformation describe-stack-resource \
    --stack-name "${FullStack}" \
    --logical-resource-id AssetBucket \
    --query StackResourceDetail.PhysicalResourceId --output text \
    --profile "${AwsProfile}" --region "${AwsRegion}")

EnvJson=$(jq -n --arg signing "$SigningSecret" '{ SigningSecret: $signing }')
if [[ -n "$AssetBucket" ]]; then
    EnvJson=$(echo "$EnvJson" | jq --arg bucket "$AssetBucket" '. + { "ASSET_BUCKET": $bucket }')
fi
if [[ -n "$ApiUrl" ]]; then
    EnvJson=$(echo "$EnvJson" | jq --arg url "$ApiUrl" '. + { "API_URL": $url }')
fi
if [[ -n "$PmtilesUrl" ]]; then
    EnvJson=$(echo "$EnvJson" | jq --arg url "$PmtilesUrl" '. + { "PMTILES_URL": $url }')
fi
if [[ -n "$GeofenceSecret" ]]; then
    EnvJson=$(echo "$EnvJson" | jq --arg geofence "$GeofenceSecret" '. + { "CLOUDTAK_Config_geofence_password": $geofence }')
fi

echo "$EnvJson" > "api/.env-${Stack}"
echo "ok - wrote api/.env-${Stack}"

cd $(pwd)/api

ssh "${Stack}-bastion" -t "pg_dump -d ${POSTGRES} > ${Stack}-latest.dump; exit"
scp "${Stack}-bastion:~/${Stack}-latest.dump" .
ssh "${Stack}-bastion" -t "rm ${Stack}-latest.dump; exit"

npm run loaddb "${Stack}-latest.dump"

npm run dev -- --env ${Stack}
